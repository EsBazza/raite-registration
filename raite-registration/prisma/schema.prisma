// prisma/schema.prisma
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(PARTICIPANT)
  clerkId       String?   @unique   // from Clerk, optional for pre-registration
  school        String?
  yearLevel     String?
  course        String?   // Added course field, optional
  uniqueId      String?   @unique // Format: SCHOOL-ID (e.g. UA-cluxyz)

  registrations Registration[]
  coachRegistrations Registration[] @relation("CoachRegistrations")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum EventSubcategory {
  ONLINE
  ONSITE
  EGAMES
}

model Event {
  id          String        @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  maxParticipantsPerRegistration Int @default(1)
  maxRegistrations               Int?
  status      EventStatus   @default(UPCOMING)
  category    String?
  subcategory EventSubcategory?
  rules       String?
  rulesPdfUrl String?
  imageUrl    String?

  registrations Registration[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Registration {
  id                   String             @id @default(cuid())
  userId               String
  eventId              String
  status               RegistrationStatus @default(PENDING)
  teamName             String?
  members              Json?              // store team members as JSON
  requirements         Json?              // file URLs or requirement flags
  adminComment         String?
  requirementsVerified Boolean            @default(false)
  registeredBy         String?            // New field to track who registered the team
  coachId              String?            // Foreign key to User

  user         User               @relation(fields: [userId], references: [id])
  coach        User?              @relation("CoachRegistrations", fields: [coachId], references: [id])
  event        Event              @relation(fields: [eventId], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([userId, eventId])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  content    String
  pinned     Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Role {
  PARTICIPANT
  ADMIN
  FACULTY_COACH
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}
